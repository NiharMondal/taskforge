# Base URL of the backend API. Used by src/lib/axios.ts.
# Copy this file to .env.local and adjust as needed.
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1

# Secret used by Auth.js (next-auth v5) to sign/encrypt the session JWT.
# REQUIRED. Generate one with: openssl rand -base64 33
# Auth.js reads AUTH_SECRET automatically (alias of NEXTAUTH_SECRET).
AUTH_SECRET=replace-me-with-a-strong-random-secret


# Cloudinary 
CLOUDINARY_CLOUD_NAME = <cloud_name>
CLOUDINARY_PRESET_NAME = <preset_name>